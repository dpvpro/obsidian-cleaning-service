{
  "name": "Plugin typescript environment",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:24-trixie",
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode"
